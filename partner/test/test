  {name:'Pro',      price:'$499', own:.30, l1:.07,  l2:.03, l3:0,   fr:0},
  {name:'VIP Elite',price:'$1 499',own:.40,l1:.10, l2:.05, l3:.02,  fr:.10},
];

let curLv = 3;

// ── AUTH ──
function sw(tab){
  document.querySelectorAll('.at').forEach((t,i)=>t.classList.toggle('on',(i===0&&tab==='login')||(i===1&&tab==='reg')));
  document.getElementById('fp-login').classList.toggle('on',tab==='login');
  document.getElementById('fp-reg').classList.toggle('on',tab==='reg');
  document.getElementById('auth').scrollIntoView({behavior:'smooth',block:'center'});
}
function showLogin(){sw('login')}function showReg(){sw('reg')}
function rp(el){document.querySelectorAll('.rpick .rp').forEach(b=>b.classList.remove('on'));el.classList.add('on')}

// ── LEVEL PICKER ──
function setLv(el, lv){
  document.querySelectorAll('.lvp').forEach(b=>b.classList.remove('on'));
  el.classList.add('on');
  curLv = lv;
  updateLvUI();
  calc();
}

function updateLvUI(){
  const lv = LVL[curLv];
  // Show/hide L1 sliders
  const hasL1 = lv.l1 > 0;
  const hasL2 = lv.l2 > 0;
  const hasL3 = lv.l3 > 0;
  const hasFr = lv.fr > 0;

  ['sl-l1-block','sl-l1c-block','sl-l1a-block'].forEach(id=>{
    document.getElementById(id).classList.toggle('sl-disabled',!hasL1);
  });
  ['div-l2','lbl-l2','sl-l2-block','sl-l2c-block'].forEach(id=>{
    document.getElementById(id).classList.toggle('sl-disabled',!hasL2);
  });
  ['div-l3','lbl-l3','sl-l3-block','sl-l3c-block'].forEach(id=>{
    document.getElementById(id).classList.toggle('sl-disabled',!hasL3);
  });
  document.getElementById('div-fr').classList.toggle('sl-disabled',!hasFr);
  document.getElementById('fr-block').classList.toggle('sl-disabled',!hasFr);

  // note updates
  document.getElementById('pn-you-label').textContent = `ВЫ (${lv.name} · ${Math.round(lv.own*100)}%)`;
  document.getElementById('pn-l1-pct').textContent = hasL1 ? `${Math.round(lv.l1*100)}% от спреда их клиентов → вам` : 'Недоступно на вашем уровне';
  document.getElementById('pn-l2-pct').textContent = hasL2 ? `${Math.round(lv.l2*100)}% от спреда их клиентов → вам` : 'Недоступно на вашем уровне';
  document.getElementById('pn-l3-pct').textContent = hasL3 ? `${Math.round(lv.l3*100)}% от спреда их клиентов → вам` : 'Только VIP Elite';

  // dim pyramid nodes
  document.getElementById('pn-l1').style.opacity = hasL1 ? '1' : '.3';
  document.getElementById('conn-l2').style.opacity = hasL2 ? '1' : '.2';
  document.getElementById('pn-l2').style.opacity = hasL2 ? '1' : '.3';
  document.getElementById('conn-l3').style.opacity = hasL3 ? '1' : '.2';
  document.getElementById('pn-l3').style.opacity = hasL3 ? '1' : '.3';
  document.getElementById('conn-fr').style.opacity = hasFr ? '1' : '.2';
  document.getElementById('pn-fr').style.opacity = hasFr ? '1' : '.3';
  document.getElementById('bar-row-l2').style.opacity = hasL2 ? '1' : '.3';
  document.getElementById('bar-row-l3').style.opacity = hasL3 ? '1' : '.3';
  document.getElementById('bar-row-fr').style.opacity = hasFr ? '1' : '.3';
}

// ── FORMAT ──
function fmtd(n){
  if(n===0) return '—';
  return '$'+Math.round(n).toLocaleString('en-US');
}
function fmts(n){return '$'+Math.round(n).toLocaleString('en-US')}

// ── SLIDER FILL ──
function fill(id){
  const sl=document.getElementById(id);
  const p=((+sl.value - +sl.min)/(+sl.max - +sl.min)*100).toFixed(1)+'%';
  sl.style.setProperty('--p',p);
}

// ── CALC ──
function calc(){
  const lv = LVL[curLv];

  const c   = +document.getElementById('sl-c').value;
  const a   = +document.getElementById('sl-a').value;
  const l1  = +document.getElementById('sl-l1').value;
  const l1c = +document.getElementById('sl-l1c').value;
  const l1a = +document.getElementById('sl-l1a').value;
  const l2  = +document.getElementById('sl-l2').value;
  const l2c = +document.getElementById('sl-l2c').value;
  const l3  = +document.getElementById('sl-l3').value;
  const l3c = +document.getElementById('sl-l3c').value;
  const fr  = +document.getElementById('sl-fr').value;
  const frp = +document.getElementById('sl-frp').value;

  // Display slider values
  document.getElementById('sv-c').textContent  = c;
  document.getElementById('sv-a').textContent  = '$'+a.toLocaleString('en-US');
  document.getElementById('sv-l1').textContent = l1;
  document.getElementById('sv-l1c').textContent= l1c;
  document.getElementById('sv-l1a').textContent= '$'+l1a.toLocaleString('en-US');
  document.getElementById('sv-l2').textContent = l2;
  document.getElementById('sv-l2c').textContent= l2c;
  document.getElementById('sv-l3').textContent = l3;
  document.getElementById('sv-l3c').textContent= l3c;
  document.getElementById('sv-fr').textContent = fr;
  document.getElementById('sv-frp').textContent= '$'+frp.toLocaleString('en-US');

  // Fill sliders
  ['sl-c','sl-a','sl-l1','sl-l1c','sl-l1a','sl-l2','sl-l2c','sl-l3','sl-l3c','sl-fr','sl-frp'].forEach(fill);

  // ── MATH ──
  // Own clients
  const ownPlatEarn = c * a * SPREAD;         // platform earns from YOUR clients
  const ownEarn     = ownPlatEarn * lv.own;   // your share

  // L1 network
  const l1TotalClients = l1 * l1c;
  const l1PlatEarn     = l1TotalClients * l1a * SPREAD;
  const l1Earn         = lv.l1 > 0 ? l1PlatEarn * lv.l1 : 0;

  // L2 network (l2 partners per L1, so total L2 = l1 * l2)
  const l2TotalPartners = l1 * l2;
  const l2TotalClients  = l2TotalPartners * l2c;
  const l2AvgVol        = l1a * 0.85; // assume L2 slightly smaller avg
  const l2PlatEarn      = l2TotalClients * l2AvgVol * SPREAD;
  const l2Earn          = lv.l2 > 0 ? l2PlatEarn * lv.l2 : 0;

  // L3 network (l3 partners per L2)
  const l3TotalPartners = l2TotalPartners * l3;
  const l3TotalClients  = l3TotalPartners * l3c;
  const l3AvgVol        = l1a * 0.70;
  const l3PlatEarn      = l3TotalClients * l3AvgVol * SPREAD;
  const l3Earn          = lv.l3 > 0 ? l3PlatEarn * lv.l3 : 0;

  // Franchise
  const frEarn = lv.fr > 0 ? fr * frp * lv.fr : 0;

  const total = ownEarn + l1Earn + l2Earn + l3Earn + frEarn;
  const year  = total * 12;

  // ── UPDATE PYRAMID ──
  document.getElementById('pn-you-detail').textContent = `${c} клиентов · $${a.toLocaleString('en-US')}/мес каждый`;
  document.getElementById('pn-you-earn').textContent   = fmts(ownEarn);

  document.getElementById('pn-l1-detail').textContent  = `${l1} партнёров · ${l1c} клиентов каждый`;
  document.getElementById('pn-l1-earn').textContent    = lv.l1 > 0 ? '+'+fmts(l1Earn) : '—';

  document.getElementById('pn-l2-detail').textContent  = `${l2TotalPartners} партнёров · ${l2c} клиентов каждый`;
  document.getElementById('pn-l2-earn').textContent    = lv.l2 > 0 ? '+'+fmts(l2Earn) : '—';

  document.getElementById('pn-l3-detail').textContent  = `${l3TotalPartners} партнёров · ${l3c} клиентов каждый`;
  document.getElementById('pn-l3-earn').textContent    = lv.l3 > 0 ? '+'+fmts(l3Earn) : '—';

  document.getElementById('pn-fr-detail').textContent  = `${fr} франшиз / мес · ср. $${frp.toLocaleString('en-US')}`;
  document.getElementById('pn-fr-earn').textContent    = lv.fr > 0 ? '+'+fmts(frEarn) : '—';

  document.getElementById('pyt-total').textContent = fmts(total);
  document.getElementById('pyt-year').textContent  = fmts(year);

  // ── BAR CHART ──
  const maxVal = Math.max(ownEarn, l1Earn, l2Earn, l3Earn, frEarn, 1);
  function setBar(barId, valId, val){
    const pct = Math.max((val/maxVal)*100,val>0?2:0).toFixed(1)+'%';
    document.getElementById(barId).style.width = pct;
    document.getElementById(valId).textContent = val>0 ? fmts(val) : '';
  }
  setBar('bar0','barv0',ownEarn);
  setBar('bar1','barv1',l1Earn);
  setBar('bar2','barv2',l2Earn);
  setBar('bar3','barv3',l3Earn);
  setBar('bar4','barv4',frEarn);
}

// ── FAQ ──
function fq(btn){
  const it=btn.parentElement;
  const was=it.classList.contains('op');
  document.querySelectorAll('.fq').forEach(q=>q.classList.remove('op'));
  if(!was)it.classList.add('op');
}

// ── REVEAL ──
const ro=new IntersectionObserver(es=>{
  es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');ro.unobserve(e.target)}});
},{threshold:.06,rootMargin:'0px 0px -40px 0px'});
document.querySelectorAll('.rv').forEach(el=>ro.observe(el));

// ── INIT ──
updateLvUI();
calc();
['sl-c','sl-a','sl-l1','sl-l1c','sl-l1a','sl-l2','sl-l2c','sl-l3','sl-l3c','sl-fr','sl-frp'].forEach(id=>{
  const sl=document.getElementById(id);
  fill(id);
  sl.addEventListener('input',()=>fill(id));
});
</script>
</body>
</html>
