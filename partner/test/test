<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>app2.cash — Партнёрская программа · MLM · до 40% от спреда</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@300;400;600;700;900&family=Manrope:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --g:#C9A84C;--g2:#E8C96D;--gd:rgba(201,168,76,.10);--gb:rgba(201,168,76,.22);
  --bg:#060606;--b1:#0B0B0B;--b2:#111;--b3:#191919;--b4:#222;
  --tx:#EDEAE0;--mu:rgba(237,234,224,.44);--di:rgba(237,234,224,.16);--ln:rgba(255,255,255,.065);
  --gr:#3DD68C;--rd:#F05252;--bl:#60A5FA;--pp:#A78BFA;--or:#FB923C;
  --lv1-c:rgba(255,255,255,.15);--lv2-c:#C9A84C;--lv3-c:#60A5FA;--lv4-c:#A78BFA;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'Manrope',sans-serif;background:var(--bg);color:var(--tx);overflow-x:hidden;min-height:100vh}
body::after{content:'';position:fixed;inset:0;background:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='f'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.88' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23f)' opacity='.032'/%3E%3C/svg%3E");pointer-events:none;z-index:9999}
.bg-grid{position:fixed;inset:0;background-image:linear-gradient(var(--ln) 1px,transparent 1px),linear-gradient(90deg,var(--ln) 1px,transparent 1px);background-size:52px 52px;pointer-events:none;z-index:0}
.bg-orb{position:fixed;border-radius:50%;filter:blur(160px);pointer-events:none;z-index:0}
.o1{width:700px;height:700px;background:rgba(201,168,76,.05);top:-200px;right:-200px}
.o2{width:500px;height:500px;background:rgba(96,165,250,.038);bottom:0;left:-150px}
.wrap{position:relative;z-index:1}

/* ── NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:200;height:58px;display:flex;align-items:center;justify-content:space-between;padding:0 56px;background:rgba(6,6,6,.9);backdrop-filter:blur(20px);border-bottom:1px solid var(--ln)}
.logo{font-family:'Unbounded',sans-serif;font-size:16px;font-weight:700;color:var(--g);text-decoration:none}
.logo sub{font-size:9px;color:var(--mu);font-weight:300;letter-spacing:.1em;text-transform:uppercase;margin-left:8px;vertical-align:middle}
.navl{display:flex;gap:28px;list-style:none}
.navl a{font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--mu);text-decoration:none;transition:color .2s}
.navl a:hover{color:var(--g)}
.nav-btn{font-family:'Manrope',sans-serif;font-size:12px;font-weight:600;padding:7px 18px;border-radius:3px;cursor:pointer;text-decoration:none;border:none;transition:all .2s}
.nb-o{background:transparent;color:var(--tx);border:1px solid var(--ln)}.nb-o:hover{border-color:var(--gb)}
.nb-g{background:var(--g);color:var(--bg)}.nb-g:hover{background:var(--g2)}
.nav-d{display:flex;gap:8px}

/* ── HERO */
.hero{min-height:100vh;padding-top:58px;display:grid;grid-template-columns:56% 44%;align-items:stretch}
.hero-l{padding:72px 48px 72px 72px;display:flex;flex-direction:column;justify-content:center;animation:fu .7s ease both}
.hero-r{border-left:1px solid var(--ln);display:flex;flex-direction:column;justify-content:center;padding:48px;animation:fu .7s .1s ease both}
.badge{display:inline-flex;align-items:center;gap:8px;border:1px solid var(--gb);background:var(--gd);border-radius:2px;padding:5px 14px;font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--g);margin-bottom:32px;width:fit-content}
.bdot{width:6px;height:6px;border-radius:50%;background:var(--gr);animation:blink 2s ease infinite}
h1{font-family:'Unbounded',sans-serif;font-size:clamp(36px,4.8vw,68px);font-weight:900;line-height:.92;letter-spacing:-.035em;margin-bottom:10px}
.h1-hl{color:var(--g)}
.h1-sub{display:block;font-size:.42em;font-weight:300;color:var(--mu);margin-top:14px;letter-spacing:-.01em;line-height:1.4}
.hero-desc{font-size:15px;color:var(--mu);line-height:1.8;max-width:480px;margin:24px 0 36px}
.kpis{display:flex;gap:0;border:1px solid var(--ln);border-radius:3px;overflow:hidden}
.kpi{flex:1;padding:16px 18px;border-right:1px solid var(--ln)}.kpi:last-child{border-right:none}
.kpi-v{font-family:'Unbounded',sans-serif;font-size:22px;font-weight:700;color:var(--g);line-height:1}
.kpi-l{font-size:10px;color:var(--mu);text-transform:uppercase;letter-spacing:.08em;margin-top:4px}

/* auth */
.auth-box{background:var(--b2);border:1px solid var(--ln);border-radius:6px;overflow:hidden}
.auth-top{height:2px;background:linear-gradient(90deg,var(--g),transparent)}
.auth-in{padding:32px}
.atabs{display:flex;background:var(--b1);border-radius:3px;padding:3px;margin-bottom:24px}
.at{flex:1;padding:8px;text-align:center;font-size:12px;font-weight:500;background:transparent;border:none;color:var(--mu);cursor:pointer;border-radius:2px;transition:all .2s;font-family:'Manrope',sans-serif}
.at.on{background:var(--b3);color:var(--tx);box-shadow:0 1px 4px rgba(0,0,0,.5)}
.auth-h{font-family:'Unbounded',sans-serif;font-size:18px;font-weight:700;margin-bottom:4px}
.auth-s{font-size:12px;color:var(--mu);margin-bottom:22px}
.f{margin-bottom:11px}
.f label{display:block;font-size:10px;letter-spacing:.09em;text-transform:uppercase;color:var(--di);margin-bottom:6px}
.f input,.f select{width:100%;background:var(--b1);border:1px solid var(--ln);border-radius:3px;padding:10px 12px;font-family:'Manrope',sans-serif;font-size:13px;color:var(--tx);outline:none;transition:border-color .2s;-webkit-appearance:none}
.f input:focus,.f select:focus{border-color:var(--gb)}
.f input::placeholder{color:var(--di)}
.f select option{background:#111}
.f2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.sbtn{width:100%;padding:12px;background:var(--g);color:var(--bg);border:none;border-radius:3px;font-family:'Manrope',sans-serif;font-size:13px;font-weight:600;cursor:pointer;transition:background .2s;margin-top:4px}
.sbtn:hover{background:var(--g2)}
.af{text-align:center;font-size:11px;color:var(--mu);margin-top:12px}
.af a{color:var(--g);text-decoration:none}
.fp{display:none}.fp.on{display:block}
.rpick{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-bottom:12px}
.rp{padding:8px 4px;border:1px solid var(--ln);border-radius:3px;background:var(--b1);cursor:pointer;text-align:center;font-family:'Manrope',sans-serif;transition:all .2s}
.rp:hover{border-color:var(--gb)}.rp.on{border-color:var(--g);background:var(--gd)}
.rp-i{font-size:15px;margin-bottom:3px}
.rp-n{font-size:9px;color:var(--mu);letter-spacing:.04em}.rp.on .rp-n{color:var(--g)}

/* ── SECTIONS */
section{padding:80px 72px;position:relative;border-top:1px solid var(--ln)}
.stag{font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--g);margin-bottom:10px}
h2{font-family:'Unbounded',sans-serif;font-size:clamp(24px,2.8vw,42px);font-weight:700;line-height:1.05;letter-spacing:-.025em;margin-bottom:12px}
.sdesc{font-size:15px;color:var(--mu);line-height:1.8;max-width:580px;margin-bottom:52px}

/* ── INCOME STREAMS */
.streams-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--ln);border:1px solid var(--ln);border-radius:4px;overflow:hidden}
.stream-card{background:var(--b1);padding:36px 28px;position:relative;overflow:hidden;transition:background .25s}
.stream-card:hover{background:var(--b2)}
.stream-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;transition:opacity .3s}
.s1::before{background:linear-gradient(90deg,var(--g),transparent)}
.s2::before{background:linear-gradient(90deg,var(--pp),transparent)}
.s3::before{background:linear-gradient(90deg,var(--gr),transparent)}
.stream-num{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--di);letter-spacing:.1em;margin-bottom:14px}
.stream-icon{font-size:28px;margin-bottom:14px}
.stream-t{font-family:'Unbounded',sans-serif;font-size:16px;font-weight:700;margin-bottom:10px}
.stream-d{font-size:12px;color:var(--mu);line-height:1.75;margin-bottom:18px}
.stream-formula{font-family:'JetBrains Mono',monospace;font-size:11px;background:var(--b3);border:1px solid var(--ln);border-radius:3px;padding:12px 14px;line-height:1.8}
.sf-hi{color:var(--g)}.sf-gr{color:var(--gr)}.sf-mu{color:var(--mu)}
.stream-who{margin-top:12px;font-size:10px;color:var(--di);letter-spacing:.06em;text-transform:uppercase}
.stream-who span{color:var(--g)}

/* ── LEVELS */
.levels-section{background:var(--b1)}
.levels-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--ln);border:1px solid var(--ln);border-radius:4px;overflow:hidden}
.lc{background:var(--b1);padding:32px 24px;position:relative;transition:background .25s;display:flex;flex-direction:column}
.lc:hover{background:var(--b2)}
.lc.best{background:rgba(201,168,76,.06);border:none;box-shadow:inset 0 0 0 1px rgba(201,168,76,.25)}
.lc-badge{display:inline-block;font-size:9px;letter-spacing:.12em;text-transform:uppercase;padding:3px 10px;border-radius:2px;margin-bottom:16px;font-weight:600;width:fit-content}
.lv1 .lc-badge{background:rgba(255,255,255,.07);color:var(--mu);border:1px solid var(--ln)}
.lv2 .lc-badge{background:rgba(201,168,76,.12);color:var(--g);border:1px solid var(--gb)}
.lv3 .lc-badge{background:rgba(96,165,250,.1);color:var(--bl);border:1px solid rgba(96,165,250,.2)}
.lv4 .lc-badge{background:rgba(167,139,250,.1);color:var(--pp);border:1px solid rgba(167,139,250,.2)}
.lc-name{font-family:'Unbounded',sans-serif;font-size:18px;font-weight:700;margin-bottom:4px}
.lc-price{margin-bottom:20px}
.lc-price-main{font-family:'Unbounded',sans-serif;font-size:32px;font-weight:900;line-height:1}
.lv1 .lc-price-main{color:var(--mu)}
.lv2 .lc-price-main{color:var(--g)}
.lv3 .lc-price-main{color:var(--bl)}
.lv4 .lc-price-main{color:var(--pp)}
.lc-price-note{font-size:10px;color:var(--di);margin-top:4px;letter-spacing:.04em}
.lc-own{background:var(--b3);border-radius:3px;padding:14px 16px;margin-bottom:16px;text-align:center}
.lc-own-pct{font-family:'Unbounded',sans-serif;font-size:36px;font-weight:900;color:var(--g);line-height:1}
.lc-own-label{font-size:10px;color:var(--mu);margin-top:4px;line-height:1.5}
.lc-net{display:flex;flex-direction:column;gap:6px;margin-bottom:20px;min-height:80px}
.lc-net-row{display:flex;align-items:center;justify-content:space-between;font-size:11px;color:var(--mu);padding:5px 8px;border-radius:2px;background:rgba(255,255,255,.025)}
.lc-net-row .pct{font-family:'JetBrains Mono',monospace;font-size:12px}
.lc-net-row.active .pct{color:var(--g)}
.lc-net-row.inactive{opacity:.3}
.lc-perks{list-style:none;display:flex;flex-direction:column;gap:7px;margin-top:auto}
.lc-perks li{font-size:11px;color:var(--mu);display:flex;gap:6px;line-height:1.5}
.lc-perks .ck{color:var(--gr);flex-shrink:0}
.lc-perks .na{color:var(--di);flex-shrink:0}
.lc-cta{margin-top:20px;padding:11px;background:var(--g);color:var(--bg);border:none;border-radius:3px;font-family:'Manrope',sans-serif;font-size:12px;font-weight:600;cursor:pointer;text-align:center;text-decoration:none;display:block;transition:background .2s}
.lc-cta:hover{background:var(--g2)}
.lv1 .lc-cta{background:transparent;color:var(--tx);border:1px solid var(--ln)}
.lv1 .lc-cta:hover{border-color:var(--gb)}
.franchise-tag{display:inline-flex;align-items:center;gap:5px;font-size:10px;color:var(--pp);background:rgba(167,139,250,.08);border:1px solid rgba(167,139,250,.18);border-radius:2px;padding:3px 8px;margin-top:10px}

/* ── NETWORK VISUALIZATION */
.viz-section{}
.viz-wrap{display:grid;grid-template-columns:1fr 1fr;gap:32px;align-items:start}

/* Pyramid */
.pyramid-box{background:var(--b2);border:1px solid var(--ln);border-radius:6px;padding:36px 28px;position:sticky;top:70px}
.pyr-title{font-family:'Unbounded',sans-serif;font-size:14px;font-weight:700;margin-bottom:6px}
.pyr-sub{font-size:11px;color:var(--mu);margin-bottom:28px}

.pyramid{display:flex;flex-direction:column;align-items:stretch;gap:0;position:relative}

.pyr-node{border:1px solid var(--ln);border-radius:4px;padding:16px 20px;display:grid;grid-template-columns:auto 1fr auto;gap:16px;align-items:center;background:var(--b1);transition:background .2s;margin-bottom:2px;position:relative}
.pyr-node:hover{background:var(--b3)}
.pyr-node.you{border-color:var(--gb);background:var(--gd);margin-bottom:0}
.pyr-node.you .pn-label{color:var(--g)}

.pyr-connector{display:flex;justify-content:center;height:28px;position:relative;margin-bottom:0}
.pyr-connector::before{content:'';position:absolute;top:0;bottom:0;left:50%;width:1px;background:linear-gradient(180deg,var(--g),rgba(201,168,76,.2));opacity:.5}
.pyr-connector-arrow{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-size:10px;color:var(--g);background:var(--bg);padding:0 4px}

.pn-icon{font-size:18px;width:32px;text-align:center}
.pn-info{}
.pn-label{font-size:12px;font-weight:600;margin-bottom:2px}
.pn-detail{font-size:10px;color:var(--mu)}
.pn-earn{text-align:right}
.pn-earn-val{font-family:'JetBrains Mono',monospace;font-size:16px;color:var(--gr);font-weight:500;white-space:nowrap}
.pn-earn-label{font-size:9px;color:var(--mu);text-align:right;margin-top:2px}

.pyr-total{margin-top:16px;border:1px solid var(--gb);border-radius:4px;padding:18px 20px;background:var(--gd);display:flex;justify-content:space-between;align-items:center}
.pyt-label{font-size:12px;color:var(--mu)}
.pyt-val{font-family:'Unbounded',sans-serif;font-size:28px;font-weight:900;color:var(--g)}
.pyt-period{font-size:10px;color:var(--mu);margin-top:2px}

/* income bar chart */
.income-bars{margin-top:16px;display:flex;flex-direction:column;gap:6px}
.ib-row{display:flex;align-items:center;gap:10px}
.ib-label{font-size:10px;color:var(--mu);width:88px;flex-shrink:0;text-align:right;letter-spacing:.02em}
.ib-bar-wrap{flex:1;height:20px;background:var(--b3);border-radius:2px;overflow:hidden}
.ib-bar{height:100%;border-radius:2px;transition:width .5s ease;display:flex;align-items:center;padding-left:8px;min-width:4px}
.ib-bar-val{font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:500;white-space:nowrap}
.ib-b0{background:linear-gradient(90deg,var(--g),var(--g2))}.ib-b0 .ib-bar-val{color:var(--bg)}
.ib-b1{background:linear-gradient(90deg,rgba(201,168,76,.5),rgba(201,168,76,.3))}.ib-b1 .ib-bar-val{color:var(--g2)}
.ib-b2{background:linear-gradient(90deg,rgba(201,168,76,.3),rgba(201,168,76,.15))}.ib-b2 .ib-bar-val{color:var(--g)}
.ib-b3{background:linear-gradient(90deg,rgba(167,139,250,.4),rgba(167,139,250,.2))}.ib-b3 .ib-bar-val{color:var(--pp)}
.ib-b4{background:linear-gradient(90deg,rgba(61,214,140,.3),rgba(61,214,140,.15))}.ib-b4 .ib-bar-val{color:var(--gr)}

/* Calculator */
.calc-box{background:var(--b2);border:1px solid var(--ln);border-radius:6px;padding:36px}
.calc-h{font-family:'Unbounded',sans-serif;font-size:16px;font-weight:700;margin-bottom:6px}
.calc-sub{font-size:12px;color:var(--mu);margin-bottom:28px}

/* level picker */
.lv-pick{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-bottom:28px}
.lvp{padding:10px 6px;border:1px solid var(--ln);border-radius:3px;background:var(--b1);cursor:pointer;text-align:center;font-family:'Manrope',sans-serif;transition:all .2s}
.lvp:hover{border-color:var(--gb)}
.lvp.on{border-color:var(--g);background:var(--gd)}
.lvp-name{font-size:11px;font-weight:600;margin-bottom:2px}
.lvp.on .lvp-name{color:var(--g)}
.lvp-price{font-size:9px;color:var(--mu)}
.lvp.on .lvp-price{color:var(--g);opacity:.7}

.sl-block{margin-bottom:22px}
.sl-row{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:9px}
.sl-name{font-size:12px;font-weight:500}
.sl-val{font-family:'JetBrains Mono',monospace;font-size:14px;color:var(--g)}
input[type=range]{-webkit-appearance:none;width:100%;height:2px;background:var(--ln);border-radius:1px;outline:none;cursor:pointer}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:15px;height:15px;border-radius:50%;background:var(--g);border:2px solid var(--b2);cursor:pointer;box-shadow:0 0 0 1px var(--gb)}
input[type=range]::-webkit-slider-runnable-track{background:linear-gradient(90deg,var(--g) var(--p,30%),var(--ln) var(--p,30%));height:2px;border-radius:1px}
.sl-note{font-size:10px;color:var(--di);margin-top:7px;line-height:1.6}
.sl-disabled{opacity:.35;pointer-events:none}

.divider{height:1px;background:var(--ln);margin:20px 0}

.spread-badge{display:flex;align-items:center;gap:10px;background:var(--b3);border:1px solid var(--ln);border-radius:3px;padding:12px 16px;margin-bottom:24px}
.sb-icon{font-size:16px}
.sb-text{font-size:11px;color:var(--mu);line-height:1.5}
.sb-text strong{color:var(--g);font-family:'JetBrains Mono',monospace}

/* ── COMPARE TABLE */
.compare-section{background:var(--b1)}
.ctable{width:100%;border-collapse:collapse;border:1px solid var(--ln);border-radius:4px;overflow:hidden}
.ctable th,.ctable td{padding:14px 18px;text-align:left;border-bottom:1px solid var(--ln);font-size:12px}
.ctable th{font-family:'Unbounded',sans-serif;font-size:10px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--mu);background:var(--b2)}
.ctable td:first-child{font-weight:500;color:var(--tx)}
.ctable tr:last-child td{border-bottom:none}
.ctable tr:hover td{background:rgba(255,255,255,.02)}
.ctable .yes{color:var(--gr);font-family:'JetBrains Mono',monospace;font-size:11px}
.ctable .no{color:var(--di);font-size:14px}
.ctable .pct-cell{font-family:'JetBrains Mono',monospace;font-size:13px}
.col-lv1{color:var(--mu)}.col-lv2{color:var(--g)}.col-lv3{color:var(--bl)}.col-lv4{color:var(--pp)}

/* ── EXAMPLE SCENARIO */
.scenario-section{}
.scenario-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--ln);border:1px solid var(--ln);border-radius:4px;overflow:hidden;margin-bottom:28px}
.sc{background:var(--bg);padding:28px 24px;transition:background .25s}
.sc:hover{background:var(--b2)}
.sc-title{font-size:13px;font-weight:600;margin-bottom:6px}
.sc-desc{font-size:11px;color:var(--mu);line-height:1.6;margin-bottom:18px}
.sc-math{font-family:'JetBrains Mono',monospace;font-size:11px;display:flex;flex-direction:column;gap:4px;background:var(--b2);border-radius:3px;padding:12px}
.sc-math .row{display:flex;justify-content:space-between;color:var(--mu)}
.sc-math .row.total{color:var(--g);font-weight:500;border-top:1px solid var(--ln);padding-top:6px;margin-top:2px}
.sc-month{margin-top:16px;text-align:center;font-family:'Unbounded',sans-serif;font-size:26px;font-weight:900;color:var(--g)}
.sc-month-label{font-size:10px;color:var(--mu);text-align:center;margin-top:4px}

/* ── FAQ */
.faq-list{border:1px solid var(--ln);border-radius:4px;overflow:hidden;max-width:820px}
.fq{border-bottom:1px solid var(--ln)}
.fq:last-child{border-bottom:none}
.fq-q{width:100%;padding:18px 22px;background:transparent;border:none;display:flex;justify-content:space-between;align-items:center;font-family:'Manrope',sans-serif;font-size:13px;font-weight:500;color:var(--tx);cursor:pointer;text-align:left;transition:background .2s}
.fq-q:hover{background:rgba(255,255,255,.02)}
.fq-ico{color:var(--g);font-size:16px;transition:transform .25s;flex-shrink:0;margin-left:14px}
.fq.op .fq-ico{transform:rotate(45deg)}
